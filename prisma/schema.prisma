generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id              String         @id @default(uuid())
  phone           String?        @unique
  name            String
  identity        String
  tokenLevel      String         @default("WANDERER")
  tokenScore      Int            @default(0)
  verifiedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  markets         Market[]
  vendorProfile   Vendor?
  serviceProfile  Service?
  plazaPosts      PlazaPost[]
  conversations   Conversation[]
}

model Vendor {
  id              String         @id @default(uuid())
  userId          String         @unique
  user            User           @relation(fields: [userId], references: [id])
  category        String
  style           String?
  priceRange      String?
  city            String?
  description     String?
  logo            String?
  creditScore     Int            @default(60)
  expoCount       Int            @default(0)
  goodRate        Float          @default(0.8)
  violations      Int            @default(0)
  complaints      Int            @default(0)
  booths          Booth[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Service {
  id              String         @id @default(uuid())
  userId          String         @unique
  user            User           @relation(fields: [userId], references: [id])
  category        String
  description     String?
  credentialUrl   String?
  projectCount    Int            @default(0)
  rating          Float          @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Market {
  id              String         @id @default(uuid())
  creatorId       String
  creator         User           @relation(fields: [creatorId], references: [id])
  name            String
  location        String
  date            String
  boothCount      Int
  description     String?
  layout          String?
  status          String         @default("draft")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  booths          Booth[]
}

model Booth {
  id              String         @id @default(uuid())
  marketId        String
  vendorId        String?
  number          String
  positionX       Float
  positionY       Float
  width           Float
  height          Float
  hasPower        Boolean        @default(false)
  status          String         @default("available")
  market          Market         @relation(fields: [marketId], references: [id])
  vendor          Vendor?        @relation(fields: [vendorId], references: [id])
}

model PlazaPost {
  id              String         @id @default(uuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id])
  type            String
  content         String
  relatedMarketId String?
  createdAt       DateTime       @default(now())
}

model Conversation {
  id              String         @id @default(uuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id])
  title           String?
  messages        String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}