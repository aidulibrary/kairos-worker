 flex items-center gap-1.5 px-3 py-2 group\" href=\"/arriver\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-store transition-colors duration-200\" aria-hidden=\"true\" style=\"color:var(--kairo-whisper)\"><path d=\"M15 21v-5a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v5\"></path><path d=\"M17.774 10.31a1.12 1.12 0 0 0-1.549 0 2.5 2.5 0 0 1-3.451 0 1.12 1.12 0 0 0-1.548 0 2.5 2.5 0 0 1-3.452 0 1.12 1.12 0 0 0-1.549 0 2.5 2.5 0 0 1-3.77-3.248l2.889-4.184A2 2 0 0 1 7 2h10a2 2 0 0 1 1.653.873l2.895 4.192a2.5 2.5 0 0 1-3.774 3.244\"></path><path d=\"M4 10.95V19a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8.05\"></path></svg><span class=\"text-[13px] transition-colors duration-200\" style=\"color:var(--kairo-whisper);font-family:var(--font-chinese-body)\">主理坊</span><span class=\"absolute bottom-0 left-1/2 -translate-x-1/2 h-[2px] w-[60%] rounded-full transition-all duration-200\" style=\"background:transparent;opacity:0\"></span><span class=\"absolute bottom-0 left-1/2 -translate-x-1/2 h-[2px] w-[60%] rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-200\" style=\"background:linear-gradient(90deg, transparent, var(--kairo-glimmer), transparent)\"></span></a><a class=\"relative flex items-center gap-1.5 px-3 py-2 group\" href=\"/descender\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-compass transition-colors duration-200\" aria-hidden=\"true\" style=\"color:var(--kairo-whisper)\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m16.24 7.76-1.804 5.411a2 2 0 0 1-1.265 1.265L7.76 16.24l1.804-5.411a2 2 0 0 1 1.265-1.265z\"></path></svg><span class=\"text-[13px] transition-colors duration-200\" style=\"color:var(--kairo-whisper);font-family:var(--font-chinese-body)\">赶集径</span><span class=\"absolute bottom-0 left-1/2 -translate-x-1/2 h-[2px] w-[60%] rounded-full transition-all duration-200\" style=\"background:transparent;opacity:0\"></span><span class=\"absolute bottom-0 left-1/2 -translate-x-1/2 h-[2px] w-[60%] rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-200\" style=\"background:linear-gradient(90deg, transparent, var(--kairo-glimmer), transparent)\"></span></a><a class=\"relative flex items-center gap-1.5 px-3 py-2 group\" href=\"/facilitator\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-wrench transition-colors duration-200\" aria-hidden=\"true\" style=\"color:var(--kairo-whisper)\"><path d=\"M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.106-3.105c.32-.322.863-.22.983.218a6 6 0 0 1-8.259 7.057l-7.91 7.91a1 1 0 0 1-2.999-3l7.91-7.91a6 6 0 0 1 7.057-8.259c.438.12.54.662.219.984z\"></path></svg><span class=\"text-[13px] transition-colors duration-200\" style=\"color:var(--kairo-whisper);font-family:var(--font-chinese-body)\">共建廊</span><span class=\"absolute bottom-0 left-1/2 -translate-x-1/2 h-[2px] w-[60%] rounded-full transition-all duration-200\" style=\"background:transparent;opacity:0\"></span><span class=\"absolute bottom-0 left-1/2 -translate-x-1/2 h-[2px] w-[60%] rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-200\" style=\"background:linear-gradient(90deg, transparent, var(--kairo-glimmer), transparent)\"></span></a></nav><div class=\"flex items-center gap-2\"><button class=\"p-1.5 rounded-md transition-colors\" style=\"background:var(--kairo-between)\" title=\"切换到浅色\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-sun\" aria-hidden=\"true\" style=\"color:var(--kairo-glimmer)\"><circle cx=\"12\" cy=\"12\" r=\"4\"></circle><path d=\"M12 2v2\"></path><path d=\"M12 20v2\"></path><path d=\"m4.93 4.93 1.41 1.41\"></path><path d=\"m17.66 17.66 1.41 1.41\"></path><path d=\"M2 12h2\"></path><path d=\"M20 12h2\"></path><path d=\"m6.34 17.66-1.41 1.41\"></path><path d=\"m19.07 4.93-1.41 1.41\"></path></svg></button><div class=\"w-8 h-8 rounded-full\" style=\"background:var(--kairo-between);border:1px solid var(--kairo-emerging)\"></div></div></header><main class=\"flex-1\"><div class=\"flex flex-col flex-1\"><section class=\"flex flex-col items-center justify-center gap-6 px-8 py-16 relative overflow-hidden\" style=\"background:var(--kairo-between);min-height:60vh\"><div class=\"absolute inset-0 opacity-[0.03]\" style=\"background-image:repeating-linear-gradient(45deg, oklch(0.35 0.01 270) 0px, oklch(0.35 0.01 270) 1px, transparent 1px, transparent 40px)\"></div><div class=\"relative z-10 flex flex-col items-center gap-6\"><h1 class=\"text-center\" style=\"font-family:var(--font-chinese-heading);font-size:var(--text-h0);font-weight:700;background:linear-gradient(135deg, var(--kairo-glimmer), var(--kairo-approach), var(--kairo-ember));-webkit-background-clip:text;-webkit-text-fill-color:transparent\">万物正在靠近。</h1><p class=\"text-center\" style=\"font-family:var(--font-chinese-body);font-size:var(--text-h3);color:var(--kairo-whisper)\">此刻，一些Kairos正在成形。</p></div><div class=\"relative z-10 flex gap-4 mt-8 flex-wrap justify-center\"><a href=\"/market/m-seed-1\" class=\"flex flex-col justify-center items-center gap-3 px-6 py-8 rounded-[var(--radius-card)] transition-all duration-300 hover:-translate-y-[3px] hover:shadow-lg\" style=\"width:240px;background:var(--kairo-between);border:1px solid var(--kairo-emerging)\"><div class=\"flex flex-col items-center gap-2\" style=\"font-family:var(--font-chinese-body)\"><span style=\"font-size:var(--text-body);color:var(--kairo-speak);font-weight:600\">风的第一次成形</span><span style=\"font-size:var(--text-small);color:var(--kairo-whisper)\">北京·东城区胡同深处</span><span style=\"font-size:11px;color:var(--kairo-murmur)\">2026-06-15</span></div><div class=\"flex items-center gap-2\"><span style=\"font-family:var(--font-mono);font-size:28px;font-weight:800;color:var(--kairo-glimmer)\">8</span><span style=\"font-family:var(--font-chinese-body);font-size:11px;color:var(--kairo-murmur)\">个信位</span></div></a></div></section><section class=\"px-8 py-12\"><div class=\"flex items-center justify-between mb-6\"><div class=\"flex items-center gap-3\"><h2 style=\"font-family:var(--font-chinese-heading);font-size:var(--text-h2);font-weight:700;color:var(--kairo-speak)\">风信</h2><div class=\"h-[2px] mx-auto flex-1 max-w-64\" style=\"width:80%;background:linear-gradient(90deg, transparent, var(--kairo-glimmer) 20%, var(--kairo-glimmer) 80%, transparent);border-radius:var(--radius-full)\"></div></div><button class=\"px-4 py-2 rounded-[var(--radius-button)] transition-all duration-200\" style=\"background:var(--kairo-between);border:1px solid var(--kairo-emerging);color:var(--kairo-whisper);font-family:var(--font-chinese-body);font-size:13px\">+ 发布风信</button></div><div class=\"grid grid-cols-2 gap-4\"><div class=\"p-6 flex flex-col gap-3 transition-all duration-200 hover:-translate-y-[2px]\" style=\"background:rgba(255, 255, 255, 0.06);backdrop-filter:blur(16px) saturate(180%);-webkit-backdrop-filter:blur(16px) saturate(180%);border:1px solid rgba(255, 255, 255, 0.10);border-radius:var(--radius-card);box-shadow:0 0 0 1px rgba(255, 255, 255, 0.03), 0 2px 4px rgba(0, 0, 0, 0.12), 0 8px 24px rgba(0, 0, 0, 0.18)\"><p style=\"font-family:var(--font-chinese-body);font-size:14px;color:var(--kairo-speak);line-height:1.7\">第一次降临即将到来。风吹过的地方，都听见了。</p><div class=\"flex items-center justify-between\"><span style=\"font-family:var(--font-chinese-body);font-size:11px;color:var(--kairo-murmur)\">创世主创</span><span style=\"font-family:var(--font-display);font-size:10px;color:var(--kairo-glimmer);background:var(--kairo-glimmer)15;padding:2px 8px;border-radius:9999px;border:1px solid var(--kairo-glimmer)30\">风信</span></div></div></div></section><section class=\"px-8 py-12\"><div class=\"flex items-center gap-3 mb-6\"><h2 style=\"font-family:var(--font-chinese-heading);font-size:var(--text-h2);font-weight:700;color:var(--kairo-speak)\">灯火</h2><div class=\"h-[2px] mx-auto flex-1 max-w-64\" style=\"width:80%;background:linear-gradient(90deg, transparent, var(--kairo-glimmer) 20%, var(--kairo-glimmer) 80%, transparent);border-radius:var(--radius-full)\"></div></div><div class=\"flex gap-4 overflow-x-auto pb-2\"><div style=\"min-width:320px\"><div class=\"p-6 flex flex-col gap-3 transition-all duration-200 hover:-translate-y-[2px]\" style=\"background:rgba(255, 255, 255, 0.06);backdrop-filter:blur(16px) saturate(180%);-webkit-backdrop-filter:blur(16px) saturate(180%);border:1px solid rgba(255, 255, 255, 0.10);border-radius:var(--radius-card);box-shadow:0 0 0 1px rgba(255, 255, 255, 0.03), 0 2px 4px rgba(0, 0, 0, 0.12), 0 8px 24px rgba(0, 0, 0, 0.18)\"><p style=\"font-family:var(--font-chinese-body);font-size:14px;color:var(--kairo-speak);line-height:1.7\">我准备好了信物——用三月的风和一月的霜锻的。</p><div class=\"flex items-center justify-between\"><span style=\"font-family:var(--font-chinese-body);font-size:11px;color:var(--kairo-murmur)\">风信主理人</span><span style=\"font-family:var(--font-display);font-size:10px;color:var(--kairo-arriver);background:var(--kairo-arriver)15;padding:2px 8px;border-radius:9999px;border:1px solid var(--kairo-arriver)30\">灯火</span></div></div></div></div></section><section class=\"px-8 py-12\"><div class=\"flex items-center justify-between mb-6\"><div class=\"flex items-center gap-3\"><h2 style=\"font-family:var(--font-chinese-heading);font-size:var(--text-h2);font-weight:700;color:var(--kairo-speak)\">几·坛</h2><div class=\"h-[2px] mx-auto max-w-48\" style=\"width:80%;background:linear-gradient(90deg, transparent, var(--kairo-glimmer) 20%, var(--kairo-glimmer) 80%, transparent);border-radius:var(--radius-full)\"></div></div><button class=\"px-4 py-2 rounded-[var(--radius-button)] transition-all duration-200\" style=\"background:linear-gradient(135deg, var(--kairo-glimmer), var(--kairo-ember));color:oklch(0.15 0.02 75);font-family:var(--font-chinese-body);font-size:13px;font-weight:600\">发起讨论</button></div><div class=\"flex flex-col gap-3\"><div class=\"p-6 flex flex-col gap-3 transition-all duration-200 hover:-translate-y-[2px]\" style=\"background:rgba(255, 255, 255, 0.06);backdrop-filter:blur(16px) saturate(180%);-webkit-backdrop-filter:blur(16px) saturate(180%);border:1px solid rgba(255, 255, 255, 0.10);border-radius:var(--radius-card);box-shadow:0 0 0 1px rgba(255, 255, 255, 0.03), 0 2px 4px rgba(0, 0, 0, 0.12), 0 8px 24px rgba(0, 0, 0, 0.18)\"><p style=\"font-family:var(--font-chinese-body);font-size:14px;color:var(--kairo-speak);line-height:1.7\">欢迎各位同行者。这里是广场——一切Kairos的起点。</p><div class=\"flex items-center justify-between\"><span style=\"font-family:var(--font-chinese-body);font-size:11px;color:var(--kairo-murmur)\">创世主创</span><span style=\"font-family:var(--font-display);font-size:10px;color:var(--kairo-facilitator);background:var(--kairo-facilitator)15;padding:2px 8px;border-radius:9999px;border:1px solid var(--kairo-facilitator)30\">几·坛</span></div></div></div></section><section class=\"px-8 py-12\"><div class=\"flex items-center gap-3 mb-6\"><h2 style=\"font-family:var(--font-chinese-heading);font-size:var(--text-h2);font-weight:700;color:var(--kairo-speak)\">相逢记</h2><div class=\"h-[2px] mx-auto flex-1 max-w-64\" style=\"width:80%;background:linear-gradient(90deg, transparent, var(--kairo-glimmer) 20%, var(--kairo-glimmer) 80%, transparent);border-radius:var(--radius-full)\"></div></div><div class=\"grid grid-cols-3 gap-4\"><div class=\"p-6 flex flex-col gap-3 transition-all duration-200 hover:-translate-y-[2px]\" style=\"back